# .env.local — 이 파일을 복사해서 .env.local 로 만들고 실제 값을 채우세요.
# .env.local은 절대 Git에 커밋하지 마세요!

# ── Supabase ──────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...
SUPABASE_BUCKET=images

# ── JWT ───────────────────────────────────────────────────────────────
# openssl rand -base64 64 로 생성
JWT_SECRET=CHANGE_ME_openssl_rand_base64_64_output

# ── Spring ────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ── Database (운영 환경에서만 설정) ───────────────────────────────────
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# 운영 Upstash 사용 시:
# REDIS_URL=redis://default:TOKEN@HOST:PORT

# ── CORS ──────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006
