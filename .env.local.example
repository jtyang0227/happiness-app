# .env.local — 이 파일을 복사해서 .env.local 로 만들고 실제 값을 채우세요.
# .env.local은 절대 Git에 커밋하지 마세요!

# ── Supabase ──────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...
SUPABASE_BUCKET=images

# ── JWT ───────────────────────────────────────────────────────────────
# openssl rand -base64 64 로 생성
JWT_SECRET=CHANGE_ME_openssl_rand_base64_64_output

# ── Spring ────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ── Database (운영 환경에서만 설정) ───────────────────────────────────
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# 운영 Upstash 사용 시:
# REDIS_URL=redis://default:TOKEN@HOST:PORT

# ── CORS ──────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# ── OAuth 소셜 로그인 ─────────────────────────────────────────────────
# Kakao
KAKAO_CLIENT_ID=YOUR_KAKAO_REST_API_KEY
KAKAO_CLIENT_SECRET=YOUR_KAKAO_CLIENT_SECRET
KAKAO_REDIRECT_URI=http://localhost:3000/oauth/kakao/callback

# Google (console.cloud.google.com → OAuth 2.0 클라이언트 ID)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/google/callback

# Naver (developers.naver.com → 애플리케이션 등록)
NAVER_CLIENT_ID=YOUR_NAVER_CLIENT_ID
NAVER_CLIENT_SECRET=YOUR_NAVER_CLIENT_SECRET
NAVER_REDIRECT_URI=http://localhost:3000/oauth/naver/callback

# Apple (developer.apple.com → Sign In with Apple 설정, HTTPS 필수)
APPLE_CLIENT_ID=com.happiness.gallery.web   # Services ID
APPLE_TEAM_ID=YOUR_APPLE_TEAM_ID
APPLE_KEY_ID=YOUR_APPLE_KEY_ID
APPLE_PRIVATE_KEY=YOUR_P8_PRIVATE_KEY_CONTENT  # PEM 헤더 포함 가능
APPLE_REDIRECT_URI=https://api.example.com/api/auth/oauth/apple/callback
APPLE_FRONTEND_REDIRECT_URI=https://app.example.com/oauth/apple/result
