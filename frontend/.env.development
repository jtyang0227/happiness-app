# 개발 환경 (npm start)
REACT_APP_API_URL=http://localhost:8080
REACT_APP_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
REACT_APP_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Kakao OAuth (카카오 개발자 콘솔 → 앱 키 → REST API 키)
REACT_APP_KAKAO_APP_KEY=YOUR_KAKAO_REST_API_KEY
REACT_APP_KAKAO_REDIRECT_URI=http://localhost:3000/oauth/kakao/callback

# Google OAuth (console.cloud.google.com → OAuth 2.0 클라이언트 ID)
REACT_APP_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
REACT_APP_GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/google/callback

# Naver OAuth (developers.naver.com → 애플리케이션 등록)
REACT_APP_NAVER_CLIENT_ID=YOUR_NAVER_CLIENT_ID
REACT_APP_NAVER_REDIRECT_URI=http://localhost:3000/oauth/naver/callback

# Apple OAuth (HTTPS + 운영 도메인 필수, 로컬 개발 불가)
REACT_APP_APPLE_CLIENT_ID=com.happiness.gallery.web
REACT_APP_APPLE_REDIRECT_URI=https://api.example.com/api/auth/oauth/apple/callback
